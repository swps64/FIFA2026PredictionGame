# WorldCupGame2026 — 環境變數範本
# 複製此檔為 .env 並填入實際值（.env 已在 .gitignore 中，不會被上傳）

# ── Cosmos DB ──────────────────────────────────────────────────
# Azure Portal → Cosmos DB 帳號 → Keys → URI
COSMOS_ENDPOINT=https://YOUR-COSMOS-ACCOUNT.documents.azure.com:443/

# Azure Portal → Cosmos DB 帳號 → Keys → PRIMARY KEY
COSMOS_KEY=YOUR_COSMOS_PRIMARY_KEY

# 資料庫名稱（預設 worldcup2026）
COSMOS_DATABASE=worldcup2026

# ── Admin 密碼 ─────────────────────────────────────────────────
# Admin 密碼的 SHA-256 hash（小寫 hex）
# 產生方式（PowerShell）：
#   [System.BitConverter]::ToString([System.Security.Cryptography.SHA256]::Create().ComputeHash([System.Text.Encoding]::UTF8.GetBytes("YOUR_ADMIN_PASSWORD"))).Replace("-","").ToLower()
# 或（Node.js）：
#   node -e "const c=require('crypto');console.log(c.createHash('sha256').update('YOUR_ADMIN_PASSWORD').digest('hex'))"
ADMIN_PASSWORD_HASH=YOUR_SHA256_HASH_HERE

# ── Azure 部署（使用 azd 時才需要）────────────────────────────
AZURE_ENV_NAME=worldcup2026
AZURE_LOCATION=eastasia
AZURE_SUBSCRIPTION_ID=YOUR_SUBSCRIPTION_ID
